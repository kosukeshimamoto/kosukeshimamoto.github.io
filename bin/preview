#!/usr/bin/env bash
#
# Local preview of the site, exactly as GitHub Pages will build it.
# Run this before pushing, check http://localhost:4000, then git push.
#
#   ./bin/preview
#
# Live reload is on: save a file and the browser refreshes automatically.
# Stop the server with Ctrl-C.

set -euo pipefail

# Use the Homebrew Ruby 3.1 (github-pages / Jekyll 3.9 needs an older Ruby;
# it does not run on Ruby 3.2+ because of a removed method in Liquid).
export PATH="/opt/homebrew/opt/ruby@3.1/bin:$PATH"

# Force UTF-8 so Sass can read theme files that contain non-ASCII characters.
export LANG="en_US.UTF-8"
export LC_ALL="en_US.UTF-8"

cd "$(dirname "$0")/.."

# _config.dev.yml overrides the production URL/analytics for local use.
exec bundle exec jekyll serve --livereload --config _config.yml,_config.dev.yml "$@"
